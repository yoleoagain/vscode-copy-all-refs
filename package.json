{
  "name": "copy-all-references",
  "displayName": "Copy All References",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-all-refs.copyAllPaths",
        "title": "Copy All Reference Paths",
        "category": "References"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "copy-all-refs.copyAllPaths",
          "when": "view == references-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "copy-all-refs.copyAllPaths",
          "when": "view == references-view"
        }
      ],
      "command-palette": [
        {
          "command": "copy-all-refs.copyAllPaths"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copy-all-refs.copyAllPaths",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
